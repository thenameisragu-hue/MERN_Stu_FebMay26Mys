<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Position:relative</title>
    <style>
        nav {
            position: sticky;
            top: 0;
            background-color: coral;
            padding: 15px;
            z-index: 1000;
        }
        nav a {
            color: black;
            margin: 20px;
            text-decoration: none;
            transition: 0.3s;
        }
        nav a:hover {
            color: orange;
            font-size: 18px;
        }
        .section {
            height: 600px;
            padding: 20px;
        }
        footer {
            position: fixed;
            bottom: 0;
            width: 100%;
            background-color: coral;
            color: black;
            text-align: center;
            padding: 10px;
        }
        button {
            padding: 10px 20px;
            background-color: blue;
            color: white;
            text-align: auto;
            border: none;
            transition: 0.4s;
        }
        button:hover {
            background-color: pink;
            transform: scale(1.2);
        }
        .ball {
            width: 50px;
            height: 50px;
            background: pink;
            border-radius: 50%;
            position: relative;
            animation: bounce 1s infinite alternate;
        }
        @keyframes bounce {
            from {top: 0px;}
            to {top: 50px;}
        }
        .box1 {
            width: 150px;
            height: 150px;
            background: green;
            position: relative;
            z-index: 1;
            border-radius: 20px;
        }
        .box2 {
            width: 150px;
            height: 150px;
            background: palegreen;
            position: relative;
            top: -100px;
            left: 50px;
            z-index: 2;
            border-radius: 20px;
        }
        .container {
            position: relative;
            width: 300px;
            height: 350px;
            background-color: #a6e22e;
            border: 5px solid black;
            margin: 50px auto;
        }
        .roof {
            position: relative;
            width: 460px;
            height: 40px;
            background-color: orangered;
            border: 5px solid black;
            left: -85px;
            top: -40px;
        }
        .window1 {
            position: relative;
            width: 50px;
            height: 100px;
            background-color: yellow;
            border: 5px solid black;
            top: 20px;
            left: 30px;
        }
        .window2 {
            position: relative;
            width: 50px;
            height: 70px;
            background-color: purple;
            border: 5px solid black;
            top: -70px;
            left: 200px;
        }
        .door {
            position: relative;
            width: 80px;
            height: 150px;
            background-color: #3f51b5;
            border: 5px solid black;
            top: -40px;
            left: 100px;
        }
        h2 {
            text-align: auto;
        }
    </style>
</head>

<body>
    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
    </nav>
    <div class="section">
        <h2>Button Hover</h2>
        <button>Hover Me</button>
        <h2>Bouncing Ball</h2>
        <div class="ball"></div><br><br>
        <h2>Z-Index Example</h2>
        <div class="box1"></div>
        <div class="box2"></div>
        <h2>Home</h2>
        <div class="container">
            <div class="roof"></div>
            <div class="window1"></div>
            <div class="window2"></div>
            <div class="door"></div>
        </div><br><br><br><br>
    </div>
    <footer>
        Fixed Footer
    </footer>
</body>

</html>