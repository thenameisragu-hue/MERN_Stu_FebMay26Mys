<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Metric Snapshot Strip</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-200">
  <div class="bg-gray-100 p-6 m-8 rounded-lg shadow">
    <div class="flex items-start justify-between">
      <div class="flex space-x-12">
        <div>
          <div class="text-gray-600 tracking-wide">
            Active Users
          </div>
          <div class="text-xl font-bold leading-relaxed tracking-wide">
            12,480
          </div>
          <span class="bg-green-100 text-green-700 inline-flex items-center px-3 py-1 rounded-full">
            Up
          </span>
        </div>
        <div>
          <div class="text-gray-600 tracking-wide">
            Revenue / Mo
          </div>
          <div class="text-xl font-bold leading-relaxed tracking-wide">
            1.24k
          </div>
          <span class="bg-blue-100 text-blue-700 inline-flex items-center px-3 py-1 rounded-full">
            Stable
          </span>
        </div>
        <div>
          <div class="text-gray-600 tracking-wide">
            Error Rate
          </div>
          <div class="text-xl font-bold leading-relaxed tracking-wide">
            2.1%
          </div>
          <span class="bg-red-100 text-red-700 inline-flex items-center px-3 py-1 rounded-full">
            Down
          </span>
        </div>
      </div>
      <button class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-lg shadow">
        Download Report
      </button>
    </div>
    <div class="bg-red-100 border-l-4 border-red-500 p-3 mt-6 rounded">
      <p class="leading-relaxed text-red-700">
        Scheduled maintenance tonight  may briefly affect dashboard updates.
      </p>
    </div>
  </div>
</body>
</html>