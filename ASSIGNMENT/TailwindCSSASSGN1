<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notification Center</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center mt-30">
  <div class="bg-white p-6 rounded-lg shadow-md w-90">
   
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold tracking-wide">Notification Center</h2>
      <span class="inline-flex items-center bg-blue-100 text-blue-600 px-4 py-1 
      rounded-full text-sm font-semibold">
        3 New
      </span>
    </div>
    
    <div class="bg-red-100 border-l-4 border-red-500 p-4 rounded mb-4">
      <h3 class="text-lg font-bold mb-1">Action Required</h3>
      <p class="relative">Your last payment attempt failed. Please update your payment method to avoid service interruption.</p>
    </div>
    
    <div class="bg-yellow-100 border-l-4 border-yellow-500 p-4 rounded mb-4">
      <h3 class="text-lg font-bold mb-1">Maintenance notice</h3>
      <p class="relative">The sytstem  will undergo Maintenance tonight. Some feacture may be temporarily unavialable.</p>
    </div>
    
    <div class="flex space-x-6">
    <button class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg shadow">
        View All
      </button>
    <button class="bg-white-500 hover:bg-gray-100 text-black px-4 py-2 rounded-lg shadow">
        Dismiss
      </button>
  </div>
  </div>
</body>
</html>